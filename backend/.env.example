PORT=5000
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/pujaconnect?retryWrites=true&w=majority
JWT_SECRET=PujaConnect_Production_Secret
JWT_EXPIRES_IN=7d
NODE_ENV=production
CORS_ORIGIN=https://your-vercel-app.vercel.app

# ── Cloudinary (required for Pandit photo uploads) ─────────────
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# ── Admin seeder credentials ───────────────────────────────────
# These are used by: npm run seed
# Change BEFORE running in production!
ADMIN_EMAIL=admin@pujaconnect.com
ADMIN_PASSWORD=StrongPassword
