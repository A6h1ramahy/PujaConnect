PORT=5000
MONGO_URI=mongodb://localhost:27017/pujaconnect
JWT_SECRET=pujaconnect_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ── Cloudinary (required for Pandit photo uploads) ─────────────
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Admin seeder credentials ───────────────────────────────────
# These are used by: npm run seed
# Change BEFORE running in production!
ADMIN_EMAIL=admin@pujaconnect.com
ADMIN_PASSWORD=Admin@1234
